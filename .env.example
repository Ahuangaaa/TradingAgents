# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Market data (Tushare Pro — required for OHLCV, fundamentals, news, indicators)
# Official env name is token: https://tushare.pro/wctapi/documents/40.md
TUSHARE_TOKEN=
# Alias also accepted:
# TUSHARE_API_KEY=
NEWS_LONG_SHORT_USE_QDRANT=1
# 设为 0/false/off 关闭 ⑧ 宏观专题的 quick LLM 摘要（仍保留向量检索原文摘录，除非同时关闭原文）
NEWS_MACRO_SECTION8_LLM_REFINE=1
# 竞品列表（get_industry_peers / get_news）：后端专用提示词调用 DeepSeek Chat Completions，再用 stock_basic 校码（非 Tushare 同行业池排序）。可用以下覆盖端点/模型：
# PEER_LLM_BASE_URL=https://api.deepseek.com/v1
# PEER_LLM_MODEL=deepseek-v4-flash
# 入库新闻打标 Chat Completions（未设置时与代码默认一致）
# NEWS_TAG_LLM_MODEL=deepseek-v4-flash
# PEER_LLM_API_KEY=
# 打标传给 DeepSeek 的正文片段最大字符（已是本地去标签后的纯文本，用于抽 ticker/行业/概念）；越大越准、越耗 token
# NEWS_TAG_LLM_SNIPPET_CHARS=12000
# 入库写入前正文最大长度上限（本地 HTML 剥标签后的 ``content``）
# NEWS_TAG_LLM_CONTENT_PLAIN_MAX=8000
# 本地剥 HTML 并行（默认 8，可与打标/嵌入并发一起调）
# NEWS_HTML_STRIP_CONCURRENCY=8
# Qdrant 多批 upsert 并行（默认 1；仅当服务端扛得住时再加大）
# INGEST_UPSERT_CONCURRENCY=1
# 入库：Tushare 多 src 并行、LLM 打标多批次并行（默认 4；限流时可改为 1）
# NEWS_FETCH_CONCURRENCY=
# NEWS_TAG_LLM_CONCURRENCY=
# DashScope 嵌入：多批 HTTP 并行数，默认 4，上限 16；设为 1 则串行
# NEWS_EMBED_CONCURRENCY=

# DashScope 文本向量（入库 + Qdrant 检索）；与百炼控制台 key 一致
DASHSCOPE_API_KEY=
# 向量维度须与 Qdrant 集合一致（text-embedding-v4 默认 1024）
# EMBEDDING_DIMENSIONS=1024
